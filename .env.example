# ─── LLM (필수: 실제 리포트 생성) ─────────────────────────────
# 없으면 목(mock) 모드로 동작 — 고정 픽스처 응답으로 전체 플로우만 확인 가능
ANTHROPIC_API_KEY=

# 강제 목 모드 (키가 있어도 LLM 호출 없이 픽스처 사용): mock | real(기본)
# LLM_MODE=mock

# ─── Supabase (권장: 저장 계층) ───────────────────────────────
# 셋업 방법: docs/setup-supabase.md
# 미설정 시 .data/ 로컬 파일 스토어로 폴백(개발 확인용, UI에 "로컬 저장(dev)" 표시)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── ② 마케팅 스튜디오 주간(7/18~)에 필요 ─────────────────────
# OPENAI_API_KEY=
