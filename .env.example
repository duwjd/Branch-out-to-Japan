# 이 파일은 필요한 환경변수의 "이름"만 문서화합니다. 실제 값은 .env 에 넣고 커밋하지 마세요.
# 사용법: cp .env.example .env  후 값 채우기

# --- Phase 2 (AI 보조 진단) 대비 ---
# 서버에서만 사용. Claude API 키.
ANTHROPIC_API_KEY=

# --- Phase 1 리드 저장 (택1, 열린 결정) ---
# 외부 폼서비스를 쓸 경우의 제출 엔드포인트 (예: Formspree/Tally webhook)
LEADS_WEBHOOK_URL=

# 배포 사이트 기본 URL (메타/링크용)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
