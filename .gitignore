# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Claude Code — 개인 로컬 설정은 커밋하지 않음 (팀 공용 설정은 .claude/settings.json)
.claude/settings.local.json

# 크롤 원본 이미지는 커밋하지 않음 (저작물·대용량). 메타데이터(.jsonl/.csv/.md)와 .gitkeep은 유지
/data/raw/**/*.jpg
/data/raw/**/*.jpeg
/data/raw/**/*.png
/data/raw/**/*.webp
/data/raw/**/*.gif
/data/raw/**/*.avif

# OCR 배치 진행 상태(임시). 결과물 detail-ocr.jsonl 은 커밋함
/data/processed/.ocr-batch-state.json
# OCR 크기초과 이미지 정규화 임시 산출(재생성 가능)
/data/processed/.ocr-normalized/

# 로컬 파일 스토어 (Supabase 미설정 시 dev 폴백 — 커밋하지 않음)
/.data/

# 엔진 CLI·테스트 컴파일 산출물 (tsc -p tsconfig.node.json)
/.tmp-node/

# impeccable 디자인 훅 캐시 (도구 생성물 — 커밋하지 않음)
.impeccable/

# humanize-korean 윤문 작업 폴더 (런타임 산출물)
/_workspace/
