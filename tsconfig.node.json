{
  "//": "엔진 CLI·테스트용 컴파일 설정 — tsc(순수 JS)로 CJS를 .tmp-node/에 내보내 node로 실행한다. esbuild 계열(tsx·vitest)이 일부 머신에서 차단되는 문제의 우회(CONTRIBUTING 트러블슈팅).",
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "incremental": false,
    "outDir": ".tmp-node",
    "rootDir": ".",
    "module": "commonjs",
    "moduleResolution": "node",
    "isolatedModules": false
  },
  "include": ["lib/**/*.ts", "scripts/run-report.ts", "scripts/run-thumbnail.ts"],
  "exclude": ["node_modules", "app", "components"]
}
